# 复制为 .env 后按需修改：cp .env.example .env

# 对外端口（主机:容器 80）
APP_PORT=10015
BIND_ADDRESS=0.0.0.0

# 镜像（一般无需改）
IMAGE_APP=ghcr.io/witguang/015:latest
IMAGE_WORKER=ghcr.io/witguang/015-worker:latest
REDIS_IMAGE=redis:7-alpine
PULL_POLICY=always

# 路径
UPLOADS_DIR=./uploads
CONFIG_FILE=./config.yaml
TZ=Asia/Shanghai

# 每台 VPS 的运行时配置（镜像不会修改 Nuxt 编译产物）
SITE_ADMIN_NAME=Guang
ADMIN_EMAIL=admin@example.com
STORAGE_LIMIT=100GiB
CUSTOM_LINK=https://github.com/witguang/015
COPYRIGHT="Designed by Guang"

# 资源上限（低配 VPS 可再收紧）
APP_MEM_LIMIT=768m
APP_CPUS=1.5
WORKER_MEM_LIMIT=512m
WORKER_CPUS=1.0
REDIS_MEM_LIMIT=384m
REDIS_CPUS=0.5
REDIS_MAXMEMORY=256mb
